rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read avatar images
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Allow authenticated users to read POV images
    match /pov-images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Allow server-side uploads for user avatars (for Netlify functions)
    match /user-avatars/{userId}.jpg {
      allow read: if request.auth != null;
      allow write: if true; // Allow server uploads without authentication
    }
    
    // Allow server-side uploads for POV images (for Netlify functions)
    match /pov-images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if true; // Allow server uploads without authentication
    }
    
    // Default rule - deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
